{
    "name": "chaos-assets-bundle",
    "displayName": "Chaos Assets Bundle",
    "version": "2.3.0",
    "private": true,
    "description": "An asset bundle for developers",
    "type": "module",
    "scripts": {
        "asset:build": "pnpm install && pnpm run build",
        "asset:post-build": "./scripts/copy-links.sh",
        "build": "tsc --build",
        "build:watch": "tsc --build --watch",
        "bump": "ts-scripts bump",
        "bump-asset": "ts-scripts bump-asset",
        "docker:limit": "./scripts/docker-limit-check.sh",
        "docker:listImages": "ts-scripts images list",
        "docker:saveImages": "ts-scripts images save",
        "lint": "eslint",
        "lint:fix": "pnpm lint --fix",
        "publish:changed": "./scripts/publish.sh",
        "setup": "pnpm install && pnpm build --force",
        "test": "ts-scripts test asset --",
        "test:all": "ts-scripts test",
        "test:debug": "ts-scripts test --debug asset --",
        "test:e2e": "echo 'No e2e tests for chaos assets'",
        "test:encrypted": "echo 'No encrypted tests for chaos assets'",
        "test:watch": "ts-scripts test --watch asset --"
    },
    "devDependencies": {
        "@terascope/core-utils": "^2.6.0",
        "@terascope/eslint-config": "~1.1.31",
        "@terascope/file-asset-apis": "^2.1.0",
        "@terascope/job-components": "~2.8.0",
        "@terascope/scripts": "~2.9.1",
        "@terascope/types": "^2.6.0",
        "@types/express": "~5.0.5",
        "@types/fs-extra": "~11.0.4",
        "@types/jest": "~30.0.0",
        "@types/json2csv": "~5.0.7",
        "@types/node": "~25.6.0",
        "@types/node-gzip": "~1.1.3",
        "@types/semver": "~7.7.1",
        "@types/timsort": "~0.3.3",
        "eslint": "~9.39.1",
        "fs-extra": "~11.3.2",
        "jest": "~30.3.0",
        "jest-extended": "~7.0.0",
        "node-notifier": "~10.0.1",
        "semver": "~7.7.3",
        "teraslice-test-harness": "~2.9.0",
        "ts-jest": "~29.4.9",
        "tslib": "~2.8.1",
        "typescript": "~5.9.3"
    },
    "packageManager": "pnpm@10.30.3",
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=10.0.0"
    },
    "terascope": {
        "root": true,
        "testSuite": "unit",
        "tests": {
            "suites": {
                "unit": [
                    "minio"
                ]
            }
        }
    }
}
